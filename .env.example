# Deploy target: server hostname or IP (used by deploy-nginx.sh, deploy-website.sh)
ARCHEPLEX_SERVER=
# SSH user on that server (used by deploy scripts and setup-vm.sh for the admin account)
ARCHEPLEX_SSH_USER=
# SSH port
ARCHEPLEX_SSH_PORT=

# Healthchecks.io ping URL for scripts/check-uptime.sh
# Get this from your healthchecks.io dashboard
HEALTHCHECKS_PING_URL=https://hc-ping.com/your-uuid-here
